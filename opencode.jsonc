{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git*" : "allow",
      "docker compose rm*":"ask",
      "docker rm*":"ask"
      },
       "external_directory" : "allow",
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}

