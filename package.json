{
  "name": "qwen-openai-proxy",
  "version": "1.0.0",
  "description": "A proxy server that exposes Qwen models through an OpenAI-compatible API",
  "main": "src/index.js",
  "scripts": {
    "start": "npm run build:core && node src/index.js",
    "dev": "npm run build:core && node src/index.js",
    "build:core": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node scripts/validate-runtime.js",
    "test:simple": "node scripts/validate-runtime.js",
    "test:proxy": "node scripts/validate-runtime.js",
    "test:all": "node test-all-accounts.js",
    "auth": "node authenticate.js",
    "auth:list": "node authenticate.js list",
    "auth:add": "node authenticate.js add",
    "auth:remove": "node authenticate.js remove",
    "auth:counts": "node authenticate.js counts",
    "auth:tokens": "node usage.js",
    "tokens": "node usage.js",
    "usage": "node usage.js"
  },
  "keywords": [
    "qwen",
    "openai",
    "proxy",
    "api"
  ],
  "author": "Qwen Code Developer",
  "license": "Apache-2.0",
  "dependencies": {
    "axios": "^1.11.0",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "open": "^8.4.0",
    "openai": "^4.20.0",
    "qrcode-terminal": "^0.12.0",
    "tiktoken": "^1.0.22",
    "undici": "^7.13.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.0.1",
    "typescript": "^6.0.2"
  }
}
