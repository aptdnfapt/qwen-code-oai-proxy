{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "authenticate.ts",
    "usage.ts",
    "test-all-accounts.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "qwen-code",
    "src/tui/**/*"
  ]
}
